{
  "name": "@lumina/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "node --env-file=.dev.vars ../../node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.dev.vars ../../node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.0.0"
  }
}
